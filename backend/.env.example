# ─── Storage Configuration ───────────────────────────
# STORAGE_MODE: cloud | sql | auto
#   cloud = Firebase Firestore (default, always available)
#   sql   = SQLAlchemy SQLite/PostgreSQL only
#   auto  = Try SQL first, fallback to Firebase on failure
STORAGE_MODE=cloud

# SQL Database (used when STORAGE_MODE=sql or auto)
DATABASE_URL=sqlite+aiosqlite:///./neurorelief.db

# ─── Firebase Configuration ──────────────────────────
# Path to Firebase service account credentials JSON file
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_CREDENTIALS=firebase-credentials.json

# ─── Gemma 4 AI Configuration ───────────────────────
# API key from Google AI Studio: https://aistudio.google.com/apikey
# Used for AI-powered severity extraction in report triage
# If not set, falls back to keyword-based severity extraction
GEMINI_API_KEY=

# ─── CORS Configuration ─────────────────────────────
# Comma-separated list of allowed origins (default: * for dev)
# Example: https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*
